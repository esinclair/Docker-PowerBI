                  <To ColumnOwner="Companies" ColumnName="company_id" />
                </On>
              </Join>
            </Joins>
          </QueryDefinition>
        </rd:DesignerState>
        <CommandText>SELECT
  Users.user_id AS [Users user_id]
  ,Users.username
  ,Users.email
  ,Users.first_name
  ,Users.last_name
  ,Users.company_id AS [Users company_id]
  ,Users.department_id AS [Users department_id]
  ,Users.manager_id
  ,Users.job_title
  ,Users.hire_date
  ,Users.is_active AS [Users is_active]
  ,Users.created_at AS [Users created_at]
  ,TransactionTypes.type_id AS [TransactionTypes type_id]
  ,TransactionTypes.type_name
  ,TransactionTypes.description AS [TransactionTypes description]
  ,Departments.department_id AS [Departments department_id]
  ,Departments.department_name
  ,Departments.company_id AS [Departments company_id]
  ,Departments.parent_department_id
  ,Departments.is_active AS [Departments is_active]
  ,Departments.created_at AS [Departments created_at]
  ,Companies.company_id AS [Companies company_id]
  ,Companies.company_name
  ,Companies.parent_company_id
  ,Companies.company_level
  ,Companies.industry
  ,Companies.founded_date
  ,Companies.is_active AS [Companies is_active]
  ,Companies.created_at AS [Companies created_at]
  ,Transactions.transaction_id
  ,Transactions.user_id AS [Transactions user_id]
  ,Transactions.company_id AS [Transactions company_id]
  ,Transactions.transaction_date
  ,Transactions.amount
  ,Transactions.type_id AS [Transactions type_id]
  ,Transactions.description AS [Transactions description]
  ,Transactions.reference_number
  ,Transactions.status
  ,Transactions.created_at AS [Transactions created_at]
FROM
  Transactions
  INNER JOIN TransactionTypes
    ON Transactions.type_id = TransactionTypes.type_id
  INNER JOIN Users
    ON Transactions.user_id = Users.user_id
  INNER JOIN Departments
    ON Users.department_id = Departments.department_id
  INNER JOIN Companies
    ON Users.company_id = Companies.company_id AND Departments.company_id = Companies.company_id AND Transactions.company_id = Companies.company_id</CommandText>
      </Query>
