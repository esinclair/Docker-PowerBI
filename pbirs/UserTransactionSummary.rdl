            <Joins>
              <Join Type="CROSS JOIN" ColumnOwner="Transactions" />
              <Join Type="INNER JOIN" ColumnOwner="TransactionTypes">
                <On>
                  <From ColumnOwner="Transactions" ColumnName="type_id" />
                  <To ColumnOwner="TransactionTypes" ColumnName="type_id" />
                </On>
              </Join>
              <Join Type="INNER JOIN" ColumnOwner="Users">
                <On>
                  <From ColumnOwner="Transactions" ColumnName="user_id" />
                  <To ColumnOwner="Users" ColumnName="user_id" />
                </On>
              </Join>
              <Join Type="INNER JOIN" ColumnOwner="Departments">
                <On>
                  <From ColumnOwner="Users" ColumnName="department_id" />
                  <To ColumnOwner="Departments" ColumnName="department_id" />
                </On>
              </Join>
              <Join Type="INNER JOIN" ColumnOwner="Companies">
                <On>
                  <From ColumnOwner="Users" ColumnName="company_id" />
                  <To ColumnOwner="Companies" ColumnName="company_id" />
                </On>
                <On>
                  <From ColumnOwner="Departments" ColumnName="company_id" />
                  <To ColumnOwner="Companies" ColumnName="company_id" />
